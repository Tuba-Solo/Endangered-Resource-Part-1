                        organic: {
                            900: '#061710',
                            800: '#0b291d',
                            700: '#113c2b',
                            500: '#22c55e',
                            400: '#4ade80',
                        },
                        digital: {
                            900: '#081c2b',
                            500: '#06b6d4',
                            400: '#22d3ee',
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
