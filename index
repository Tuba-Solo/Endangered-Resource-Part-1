    <!-- Interactive Scripts -->
    <script>
        // Initialize Icons
        lucide.createIcons();

        // Quote Modal Logic
        function openQuoteModal(cardElement) {
            const pageText = cardElement.querySelector('.font-mono').innerText;
            const quoteText = cardElement.querySelector('.font-serif').innerText;
            
            document.getElementById('quote-modal-page').innerText = pageText;
            document.getElementById('quote-modal-text').innerText = quoteText;
            
            const modal = document.getElementById('quote-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            // Trigger reflow for transition
            void modal.offsetWidth;
            
            modal.classList.remove('opacity-0');
            modal.classList.add('opacity-100');
        }

        function closeQuoteModal() {
            const modal = document.getElementById('quote-modal');
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 300); // Wait for transition duration
        }

        // Close modal on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeQuoteModal();
        });

        // SPA Navigation Logic
        function navTo(targetId) {
            // Hide all pages
            document.querySelectorAll('.page-section').forEach(el => {
                el.classList.add('hidden');
            });
            
            // Show target
            const target = document.getElementById(targetId);
            if (target) {
                target.classList.remove('hidden');
                
                // Trigger reveals immediately for SPA feel
                const targetReveals = target.querySelectorAll('.reveal');
                targetReveals.forEach(el => {
                    el.classList.remove('active');
                    setTimeout(() => el.classList.add('active'), 50);
                });
            }

            // Update Desktop Nav
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('text-white', 'bg-organic-900/50', 'border-organic-500/30', 'bg-digital-900/50', 'border-digital-500/50', 'text-digital-400');
                if (btn.id === 'nav-pl') {
                    btn.classList.add('text-digital-400', 'border-digital-400/10');
                } else {
                    btn.classList.add('text-slate-400', 'border-transparent');
                }
            });

            // Set active state
            const activeBtn = document.getElementById('nav-' + targetId);
            if (activeBtn) {
                if (targetId === 'pl') {
                    activeBtn.classList.remove('border-digital-400/10');
                    activeBtn.classList.add('bg-digital-900/50', 'border-digital-500/50', 'text-digital-400');
                } else {
                    activeBtn.classList.remove('text-slate-400', 'border-transparent');
                    activeBtn.classList.add('text-white', 'bg-organic-900/50', 'border', 'border-organic-500/30');
                }
            }

            // Scroll to top
            const mainContent = document.querySelector('main');
            if(mainContent) mainContent.scrollTop = 0;
        }

        // Initialize active page reveals
        setTimeout(() => {
            document.querySelectorAll('#home .reveal').forEach(el => el.classList.add('active'));
        }, 100);

        // Accordion Logic
        const accordionItems = document.querySelectorAll('.accordion-item');
        
        accordionItems.forEach(item => {
            const button = item.querySelector('button');
            const content = item.querySelector('.accordion-content');
            const icon = item.querySelector('i[data-lucide="chevron-down"]');

            button.addEventListener('click', () => {
                const isOpen = content.style.maxHeight;

                // Close all others
                accordionItems.forEach(otherItem => {
                    const otherContent = otherItem.querySelector('.accordion-content');
                    const otherIcon = otherItem.querySelector('i[data-lucide="chevron-down"]');
                    otherContent.style.maxHeight = null;
                    if(otherIcon) otherIcon.style.transform = 'rotate(0deg)';
                });

                // Toggle current
                if (!isOpen) {
                    content.style.maxHeight = content.scrollHeight + "px";
                    if(icon) icon.style.transform = 'rotate(180deg)';
                }
            });
        });

        // Network Background Animation (Organic / Digital Blend)
        const canvas = document.getElementById('network-canvas');
        const ctx = canvas.getContext('2d');
        
        let width, height;
        let particles = [];
        
        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }

        window.addEventListener('resize', resize);
        resize();

        class Particle {
            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                // Randomly assign organic (emerald) or digital (cyan) color
                this.isOrganic = Math.random() > 0.5; 
                this.baseSize = Math.random() * 2 + 1;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                // Bounce off edges
                if (this.x < 0 || this.x > width) this.vx *= -1;
                if (this.y < 0 || this.y > height) this.vy *= -1;
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.baseSize, 0, Math.PI * 2);
                ctx.fillStyle = this.isOrganic ? 'rgba(16, 185, 129, 0.5)' : 'rgba(6, 182, 212, 0.5)';
                ctx.fill();
            }
        }

        function initParticles() {
            particles = [];
            const numParticles = Math.min(Math.floor(width * height / 15000), 100);
            for (let i = 0; i < numParticles; i++) {
                particles.push(new Particle());
            }
        }

        // Mouse interaction
        let mouse = { x: null, y: null };
        window.addEventListener('mousemove', (e) => {
            mouse.x = e.x;
            mouse.y = e.y;
        });

        function animate() {
            ctx.clearRect(0, 0, width, height);

            particles.forEach((p, index) => {
                p.update();
                p.draw();

                // Connect particles
                for (let j = index + 1; j < particles.length; j++) {
                    const p2 = particles[j];
                    const dx = p.x - p2.x;
                    const dy = p.y - p2.y;
                    const distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < 150) {
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                        ctx.lineTo(p2.x, p2.y);
                        
                        // Line color based on connected nodes
                        const alpha = 1 - (distance / 150);
                        if (p.isOrganic && p2.isOrganic) {
                            ctx.strokeStyle = `rgba(16, 185, 129, ${alpha * 0.2})`; // Emerald link
                        } else if (!p.isOrganic && !p2.isOrganic) {
                            ctx.strokeStyle = `rgba(6, 182, 212, ${alpha * 0.2})`; // Cyan link
                        } else {
                            ctx.strokeStyle = `rgba(148, 163, 184, ${alpha * 0.1})`; // Neutral link
                        }
                        
                        ctx.lineWidth = 1;
                        ctx.stroke();
                    }
                }

                // Connect to mouse
                if (mouse.x != null) {
                    const dx = p.x - mouse.x;
                    const dy = p.y - mouse.y;
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    if (distance < 200) {
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                        ctx.lineTo(mouse.x, mouse.y);
                        ctx.strokeStyle = p.isOrganic ? `rgba(16, 185, 129, 0.1)` : `rgba(6, 182, 212, 0.1)`;
                        ctx.stroke();
                        
                        // slight attraction
                        p.x -= dx * 0.002;
                        p.y -= dy * 0.002;
                    }
                }
            });

            requestAnimationFrame(animate);
        }

        initParticles();
        animate();
    </script>
